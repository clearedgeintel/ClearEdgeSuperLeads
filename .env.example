# Database (Neon PostgreSQL)
DATABASE_URL=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Custom Search (for lead discovery)
GOOGLE_CUSTOM_SEARCH_API_KEY=
GOOGLE_CUSTOM_SEARCH_ENGINE_ID=

# Anthropic (for AI lead scoring and email generation)
ANTHROPIC_API_KEY=

# Google Places API (for lead enrichment — can use same key as Custom Search)
GOOGLE_PLACES_API_KEY=

# HubSpot Private App access token (for pushing leads to HubSpot CRM)
HUBSPOT_ACCESS_TOKEN=

# Gmail SMTP (for outreach emails)
GMAIL_USER=
GMAIL_PASSWORD=

# Session
SESSION_SECRET=

# App URL (used for OAuth callback and email tracking links)
APP_URL=http://localhost:5000

# Port (Railway sets this automatically)
PORT=5000
